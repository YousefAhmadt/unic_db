Future<void> seedCourseSchedules() async {
  final coursesResult = await connection.execute('''
    SELECT id
    FROM courses
    ORDER BY id;
  ''');

  final sunTueThuSlots = [
    ['08:00', '09:00'],
    ['09:00', '10:00'],
    ['10:00', '11:00'],
    ['11:00', '12:00'],
    ['12:00', '13:00'],
  ];

  final monWedSlots = [
    ['08:30', '10:00'],
    ['10:00', '11:30'],
    ['11:30', '13:00'],
    ['13:00', '14:30'],
    ['14:30', '16:00'],
  ];

  int index = 0;

  for (final row in coursesResult) {
    final courseId = row[0].toString();

    final slotA = sunTueThuSlots[index % sunTueThuSlots.length];
    final slotB = monWedSlots[index % monWedSlots.length];

    // Section A: Sunday + Tuesday + Thursday
    for (final day in ['Sunday', 'Tuesday', 'Thursday']) {
      await connection.execute(
        Sql.named('''
          INSERT INTO course_schedules
          (course_id, section, semester_id, day, start_time, end_time, room, professor_id)
          VALUES
          (@courseId, 'A', 1, @day, @startTime, @endTime, @room, 'PROF001')
          ON CONFLICT DO NOTHING;
        '''),
        parameters: {
          'courseId': courseId,
          'day': day,
          'startTime': slotA[0],
          'endTime': slotA[1],
          'room': 'Room ${100 + index}',
        },
      );
    }

    // Section B: Monday + Wednesday
    for (final day in ['Monday', 'Wednesday']) {
      await connection.execute(
        Sql.named('''
          INSERT INTO course_schedules
          (course_id, section, semester_id, day, start_time, end_time, room, professor_id)
          VALUES
          (@courseId, 'B', 1, @day, @startTime, @endTime, @room, 'PROF001')
          ON CONFLICT DO NOTHING;
        '''),
        parameters: {
          'courseId': courseId,
          'day': day,
          'startTime': slotB[0],
          'endTime': slotB[1],
          'room': 'Room ${200 + index}',
        },
      );
    }

    index++;
  }
}

