  // =========================
  // 9. TRIGGER (PREREQUISITES SYNC)
  // =========================
  Future<void> create_TRIGGER() async {

    // 1️⃣ FUNCTION
    await connection.execute(r'''
      CREATE OR REPLACE FUNCTION sync_prerequisites()
      RETURNS TRIGGER AS $$
      BEGIN
        IF TG_OP = 'UPDATE'
        AND OLD.prerequisites IS NOT DISTINCT FROM NEW.prerequisites THEN
          RETURN NEW;
        END IF;

        DELETE FROM course_prerequisites WHERE course_id = NEW.id;

        IF array_length(NEW.prerequisites, 1) IS NOT NULL THEN
          INSERT INTO course_prerequisites (course_id, prerequisite_id)
          SELECT NEW.id, unnest(NEW.prerequisites);
        END IF;

        RETURN NEW;
      END;
      $$ LANGUAGE plpgsql;
    ''');

    // 2️⃣ DROP TRIGGER
    await connection.execute('''
      DROP TRIGGER IF EXISTS trg_sync_prerequisites ON courses;
    ''');

    // 3️⃣ CREATE TRIGGER
    await connection.execute('''
      CREATE TRIGGER trg_sync_prerequisites
      AFTER INSERT OR UPDATE ON courses
      FOR EACH ROW
      EXECUTE FUNCTION sync_prerequisites();
    ''');
  }

